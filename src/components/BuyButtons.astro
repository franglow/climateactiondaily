---
// src/components/BuyButtons.astro
import CtaButton from './CtaButton.astro';

const retailers = Astro.props.retailers ?? [];
const variant = Astro.props.variant ?? 'default';
---

{retailers.length > 0 && (
  <div class={variant === 'single' ? 'mt-4 flex justify-center' : 'mt-6 flex flex-wrap gap-3'}>
    {retailers.map((r) => {
      const isAmazon = r.name.toLowerCase().startsWith('amazon');
      return (
        <CtaButton
          name={r.name}
          url={r.url}
          variant={isAmazon ? 'amazon' : 'default'}
          size={variant === 'single' ? 'large' : 'small'}
        />
      );
    })}
  </div>
)}