---
interface Props {
  headline: string; 
  sub: string;
  id?: string;
}
const { headline, sub, id = "intro-headline" } = Astro.props;
---
<section id={id} aria-labelledby={`${id}-title`} class="mt-8 md:mt-10 my-20">
  <header class="max-w-5xl mx-auto px-6 md:px-8 text-center">
    <h1
      id={`${id}-title`}
      class="font-serif text-3xl my-10 md:text-4xl font-bold leading-tight tracking-tight text-center max-w-5xl mx-auto px-4 text-[color:var(--base-ink)] contrast-more:text-[color:var(--base-ink)]"
    >
      {headline}
    </h1>

    <p class="mt-4 text-base md:text-lg text-[color:var(--base-ink)]/90 contrast-more:text-[color:var(--base-ink)]">
      {sub}
    </p>
  </header>
</section>