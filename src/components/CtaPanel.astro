---
import CtaButton from "./CtaButton.astro";

interface Retailer { name: string; url: string }
interface Props { title: string; retailers: Retailer[] }

const { title, retailers } = Astro.props;
---
<section class="mt-10 my-20 md:mt-12">
  <div class="max-w-4xl mx-auto bg-[color:var(--base-cta)] rounded-md py-6 px-6 text-center">
    <h3 class="text-lg md:text-xl font-semibold leading-tight">{title}</h3>

    <div class="mt-4 flex justify-center gap-4 flex-wrap">
      {retailers.map((r) => {
        const isAmazon = r.name.toLowerCase().startsWith('amazon');
        return (
          <CtaButton
            name={r.name}
            url={r.url}
            variant={isAmazon ? 'amazon' : 'default'}
            size="large"
          />
        );
      })}
    </div>
  </div>
</section>