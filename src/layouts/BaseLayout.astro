---
import "../styles/tailwind.css";
import SEOHead from "../components/seo/SEOHead.astro";

interface Props {
  title?: string;
  description?: string;
  ogImage?: string;
  lang?: string;
  jsonLd?: object | object[];
}

const {
  title = 'Climate Change: A Guide to Everyday Action',
  description = 'A practical guide to sustainable living and personal growth.',
  ogImage = '/og.jpg',
  lang = 'en',
  jsonLd,
} = Astro.props;

const canonicalUrl = Astro.url.href;
const domain = 'climateactiondaily.com';
---
<!doctype html>
<html lang={lang}>
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>{title}</title>

    <SEOHead
      title={title}
      description={description}
      canonicalUrl={canonicalUrl}
      ogImage={ogImage}
      jsonLd={jsonLd}
    />

    <!-- Fonts with font-display: swap -->
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=Libre+Baskerville:wght@700&display=swap" rel="stylesheet">

    <!-- Plausible (analytics) -->
    <script defer data-domain={domain} src="https://plausible.io/js/script.js"></script>

    <link rel="preload"
          as="image"
          href="/images/climate-change-320.webp"
          imagesrcset="/images/climate-change-320.webp 320w, /images/climate-change-480.webp 480w, /images/climate-change-768.webp 768w, /images/climate-change-1024.webp 1024w"
          imagesizes="(min-width: 768px) 340px, 80vw">
    <link rel="preload"
      as="image"
      href="/images/cover.png"
      imagesrcset="/images/climate-change.png 1024w"
      imagesizes="100vw"
      type="image/png">
  </head>
  <body class="bg-base-bg text-base-ink font-sans antialiased">
    <a href="#main" class="sr-only focus:not-sr-only focus:absolute focus:top-2 focus:left-2 bg-white px-3 py-2 rounded">
      Skip to main content
    </a>
    <main id="main" class="mx-auto max-w-6xl px-4 md:px-6">
      <slot />
    </main>
    <footer class="border-t border-base-line bg-white/70 mt-12">
      <div class="mx-auto max-w-6xl px-4 md:px-6 py-8 text-sm text-base-subtle">
        © {new Date().getFullYear()} Fran C. Wood
      </div>
    </footer>
  </body>
</html>
